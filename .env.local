# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and should never be committed.

# GitHub repository details for the Release Notes page.
# The app fetches releases from: https://api.github.com/repos/{OWNER}/{REPO}/releases
VITE_GITHUB_OWNER=vg1979-commits
VITE_GITHUB_REPO=retirement-planner
